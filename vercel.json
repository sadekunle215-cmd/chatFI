{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "regions": ["iad1"],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/yield-vault.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/jupiter.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "crons": [
    { "path": "/api/yield-vault?cron=rotator", "schedule": "*/5 * * * *" }
  ]
}
